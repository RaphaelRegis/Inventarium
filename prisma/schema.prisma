// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STOCKIST
}

model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  taxIdentification String   @unique @map("tax_identification")
  phoneNumber       String?  @map("phone_number")
  role              UserRole @default(STOCKIST)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("users")
}

model Branch {
  id          String   @id @default(uuid())
  name        String
  address     String
  phoneNumber String?  @map("phone_number")
  email       String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inventories Inventory[]
  productEntries ProductEntry[]
  productOutputs ProductOutput[]

  @@map("branches")
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String?  @map("phone_number")
  email       String?  @unique
  website     String?
  debt        Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[] @relation("ProductSuppliers")
  productEntries ProductEntry[]

  @@map("suppliers")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String?
  remarks       String?
  purchasePrice Decimal  @map("purchase_price") @db.Decimal(10, 2)
  retailPrice   Decimal  @map("retail_price") @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  suppliers     Supplier[] @relation("ProductSuppliers")
  inventories   Inventory[]
  productEntryItems ProductEntryItem[]
  productOutputItems ProductOutputItem[]

  @@map("products")
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  address     String
  phoneNumber String?  @map("phone_number")
  email       String?  @unique
  debt        Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  productOutputs ProductOutput[]

  @@map("customers")
}

model Inventory {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  branchId  String   @map("branch_id")
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
  @@map("inventories")
}

model ProductEntry {
  id         String   @id @default(uuid())
  date       DateTime @default(now())
  supplierId String   @map("supplier_id")
  branchId   String   @map("branch_id")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier Supplier           @relation(fields: [supplierId], references: [id])
  branch   Branch             @relation(fields: [branchId], references: [id])
  items    ProductEntryItem[]

  @@map("product_entries")
}

model ProductEntryItem {
  id             String @id @default(uuid())
  productEntryId String @map("product_entry_id")
  productId      String @map("product_id")
  quantity       Int

  productEntry ProductEntry @relation(fields: [productEntryId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@map("product_entry_items")
}

model ProductOutput {
  id         String   @id @default(uuid())
  date       DateTime @default(now())
  customerId String?  @map("customer_id")
  branchId   String   @map("branch_id")
  totalValue Decimal  @map("total_value") @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer?           @relation(fields: [customerId], references: [id])
  branch   Branch              @relation(fields: [branchId], references: [id])
  items    ProductOutputItem[]

  @@map("product_outputs")
}

model ProductOutputItem {
  id              String  @id @default(uuid())
  productOutputId String  @map("product_output_id")
  productId       String  @map("product_id")
  quantity        Int
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)

  productOutput ProductOutput @relation(fields: [productOutputId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("product_output_items")
}
